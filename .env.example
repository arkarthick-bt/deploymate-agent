# Agent identity
AGENT_TOKEN=your_agent_token_here
SERVER_ID=your_server_id_here

# Backend connection
BACKEND_WS_URL=ws://localhost:8081/ws/agents
BACKEND_HTTP_URL=http://localhost:8081

# Docker settings
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_NETWORK_PREFIX=deploymate
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=1

# Traefik
TRAEFIK_NETWORK=traefik-public
TRAEFIK_DOMAIN=localhost

# Git workspace
WORKSPACE_DIR=/tmp/deploymate-agent/workspaces

# Heartbeat interval in milliseconds
HEARTBEAT_INTERVAL_MS=30000

# Deployment timeout in milliseconds
DEPLOYMENT_TIMEOUT_MS=600000

# Health check settings
HEALTH_CHECK_RETRIES=10
HEALTH_CHECK_INTERVAL_MS=5000
HEALTH_CHECK_TIMEOUT_MS=30000

# Log level: error | warn | info | debug
LOG_LEVEL=info
